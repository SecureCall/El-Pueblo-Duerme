{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://elpuebloduerme.vercel.app/icons/192.png",
                  "size": "Small",
                  "style": "RoundedCorners"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "El Pueblo Duerme",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Light"
                },
                {
                  "type": "TextBlock",
                  "text": "${status}",
                  "spacing": "None",
                  "color": "Attention",
                  "size": "Small"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${message}",
      "wrap": true,
      "size": "Small",
      "color": "Default"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Jugar Ahora",
      "url": "https://elpuebloduerme.vercel.app/?source=widget"
    }
  ]
}
