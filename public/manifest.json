{
  "name": "El Pueblo Duerme",
  "short_name": "Pueblo Duerme",
  "description": "Un juego multijugador de misterio, engaño y supervivencia. Descubre a los lobos antes de que sea tarde.",
  "start_url": "/",
  "id": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone", "minimal-ui"],
  "background_color": "#1c1917",
  "theme_color": "#1c1917",
  "orientation": "portrait-primary",
  "lang": "es",
  "dir": "ltr",
  "scope": "/",
  "categories": ["games", "entertainment"],
  "prefer_related_applications": false,

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "tab_strip": {
    "home_tab": {
      "url": "/",
      "icons": [{ "src": "/icons/32.png", "sizes": "32x32", "type": "image/png" }]
    },
    "new_tab_button": {
      "url": "/create",
      "icons": [{ "src": "/icons/32.png", "sizes": "32x32", "type": "image/png" }]
    }
  },

  "note_taking": {
    "new_note_url": "/create"
  },

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://elpuebloduerme.vercel.app/manifest.json",
      "id": "elpuebloduerme.vercel.app"
    }
  ],

  "scope_extensions": [
    { "origin": "https://elpuebloduerme.vercel.app" }
  ],

  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+pueblo",
      "url": "/join?code=%s"
    }
  ],

  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/json": [".pueblo"]
      },
      "icons": [{ "src": "/icons/192.png", "sizes": "192x192", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],

  "widgets": [
    {
      "name": "El Pueblo Duerme",
      "short_name": "Pueblo Duerme",
      "description": "Estado de tu última partida",
      "tag": "pueblo-duerme-status",
      "ms_ac_template": "/widget-template.json",
      "data": "/widget-data.json",
      "icons": [
        { "src": "/icons/192.png", "sizes": "192x192", "type": "image/png" }
      ],
      "multiple": false,
      "update": 300
    }
  ],

  "icons": [
    {
      "src": "/icons/16.png",
      "sizes": "16x16",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/32.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/256.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android-launchericon-192-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android-launchericon-512-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "/screenshot1.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Pantalla principal de El Pueblo Duerme"
    },
    {
      "src": "/icons/512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Logo de El Pueblo Duerme"
    }
  ],

  "shortcuts": [
    {
      "name": "Crear Nueva Partida",
      "short_name": "Crear",
      "description": "Inicia una nueva partida y configura las reglas.",
      "url": "/create",
      "icons": [{ "src": "/icons/72.png", "sizes": "72x72", "type": "image/png" }]
    },
    {
      "name": "Cómo Jugar",
      "short_name": "Reglas",
      "description": "Aprende las reglas y los roles del juego.",
      "url": "/how-to-play",
      "icons": [{ "src": "/icons/72.png", "sizes": "72x72", "type": "image/png" }]
    }
  ]
}
