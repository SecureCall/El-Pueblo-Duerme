rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isHost(gameData) {
      return request.auth.uid == gameData.hostUid;
    }

    function isPlayerInGame(gameId) {
      let game = get(/databases/$(database)/documents/games/$(gameId));
      let players = game.data.players;
      return players != null && request.auth.uid in players.keys();
    }

    function isPlayerInGameByArray(gameId) {
      // Check if the user is in the players array (array of maps)
      return isAuth();
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }

    // ── Games ──────────────────────────────────────────────────────────────
    match /games/{gameId} {
      // Any logged-in user can read games (for listing public rooms, joining by code)
      allow read: if isAuth();

      // Any logged-in user can create a game
      allow create: if isAuth() && request.auth.uid == request.resource.data.hostUid;

      // Host can update any game field; players can update the players array (joining)
      allow update: if isAuth() && (
        request.auth.uid == resource.data.hostUid ||
        // Allow joining: only the players array is being added to
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'playerCount']))
      );

      allow delete: if isAuth() && request.auth.uid == resource.data.hostUid;
    }

    // ── Chat channels ──────────────────────────────────────────────────────
    match /games/{gameId}/publicChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/lobbyChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/ghostChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/wolfChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/loversChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/twinChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/fairyChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == request.resource.data.senderId || request.resource.data.senderId == 'system');
      allow update, delete: if false;
    }

    match /games/{gameId}/nightActions/{actionId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow delete: if false;
    }

    match /games/{gameId}/votes/{voteId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.auth.uid == request.resource.data.voterId;
      allow delete: if false;
    }
  }
}
