rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isHost(gameId) {
      return request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid;
    }

    function onlyUpdating(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function affectedAre(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    // ── Fields exclusively controlled by the host ─────────────────────────
    // A player triggering any of these in an updateDoc is REJECTED.
    // ADD any new host-only field here.
    function touchesSensitiveFields() {
      return affectedAre([
        // Identity & control
        'hostUid', 'code',
        // Phase machine — only host may advance phases
        'roles', 'phase', 'status', 'winners', 'winMessage',
        // Wolf team map (used for wolfChat Firestore rule)
        'wolfTeam',
        // Timeline & round tracking
        'eliminatedHistory', 'roundNumber', 'nightStartedAt', 'dayStartedAt',
        'dayDuration', 'dayEliminatedUid',
        // Events & modifiers
        'currentEvent', 'eventRound',
        // Role-specific outcome fields written only during processNight
        'seerReveal', 'profetaReveal',
        'saboteadorBan', 'forenseResults', 'iluminadoReveal',
        'noExileActive', 'eclipseActive', 'anonymousVotesActive',
        'lovers', 'silencedPlayers', 'enchanted',
        'bearGrowl', 'lobosBlocked',
        'brujaProtectedUid', 'hechiceraLifeUsed', 'hechiceraPoisonUsed',
        'vampiroBites', 'cultMembers', 'pescadorBoat', 'malditoUid',
        'alborotadoraFight', 'alborotadoraUsed', 'juezUsed', 'voteBanned',
        'sirenaUid', 'sirenaLinked', 'cazadorPendingShot', 'chivoPendingChoice',
        'perroLoboChoices', 'salvajeMentors', 'virginiawoolFate',
        'verdugos', 'cambiaformasTargets', 'fantasmaPending', 'fantasmaUsed',
        'doubleSeerActive', 'criaLoboRage', 'vigiaUsed', 'vigiaKnowsWolves',
        'angelResucitadorUsed', 'bansheePoints', 'bansheePredictionUid',
        'alquimistaPotion', 'alquimistaRevealUid',
        'hadaLinked', 'principeUsed', 'espiaUsed',
        'antiguoHit', 'brujaFoundVidente',
        'guardianLastTarget', 'doctorLastTarget', 'doctorSelfUsed'
      ]);
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (
        request.auth.uid == userId
        || request.resource.data.diff(resource.data).affectedKeys().hasAny(['friendRequests'])
      );
    }

    // ── Presence (heartbeat during game) ───────────────────────────────────
    match /presence/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── Game invites ────────────────────────────────────────────────────────
    match /gameInvites/{userId}/items/{inviteId} {
      allow read, delete: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth();
    }

    // ── Games ──────────────────────────────────────────────────────────────
    match /games/{gameId} {
      // Public lobby games can be listed without login (for public-rooms page)
      allow read: if isAuth() || (
        resource.data.isPublic == true &&
        resource.data.status == 'lobby'
      );
      allow create: if isAuth() && request.auth.uid == request.resource.data.hostUid;

      allow update: if isAuth() && (

        // ① Host can modify anything
        request.auth.uid == resource.data.hostUid

        // ② Players can join/leave — ONLY while game is in lobby
        || (
          resource.data.status == 'lobby' &&
          onlyUpdating(['players', 'playerCount'])
        )

        // ③ Players submit night actions — no sensitive fields, only nightActions/nightSubmissions
        || (
          resource.data.phase == 'night' &&
          affectedAre(['nightActions', 'nightSubmissions']) &&
          !touchesSensitiveFields() &&
          !affectedAre(['dayVotes', 'players'])
        )

        // ④ Players cast a day vote — only their own UID key, only during day phase
        || (
          (resource.data.phase == 'day' || resource.data.phase == 'voting') &&
          affectedAre(['dayVotes']) &&
          !touchesSensitiveFields() &&
          !affectedAre(['nightActions', 'nightSubmissions', 'players']) &&
          request.resource.data.dayVotes
            .diff(resource.data.dayVotes)
            .affectedKeys()
            .hasOnly([request.auth.uid])
        )

        // ⑤ Victim signature mechanics — cursed & narratorBroadcast (Últimas Palabras / Venganza)
        || (
          onlyUpdating(['cursed', 'narratorBroadcast']) &&
          (resource.data.phase == 'night' || resource.data.phase == 'day')
        )

        // ⑥ Ended games — allow minor updates (host reassignment after game ends)
        || resource.data.phase == 'ended'

        // ⑦ Host self-claim — any alive player can promote themselves to host
        //    (client-side enforces a 5-minute absence delay before triggering this)
        || (
          onlyUpdating(['hostUid', 'players']) &&
          request.resource.data.hostUid == request.auth.uid &&
          resource.data.phase != 'lobby'
        )
      );

      allow delete: if isAuth() && request.auth.uid == resource.data.hostUid;
    }

    // ── Private roles (only that player + host can read/write) ────────────
    match /games/{gameId}/playerRoles/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid
        || isHost(gameId)
      );
      allow write: if isAuth() && isHost(gameId);
    }

    // ── Reports (only host can read; any member can file) ─────────────────
    match /games/{gameId}/reports/{reportId} {
      allow read: if isAuth() && isHost(gameId);
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Night audit logs — host writes, anyone reads (debugging) ──────────
    match /games/{gameId}/nightLogs/{round} {
      allow read: if isAuth();
      allow write: if isAuth() && isHost(gameId);
    }

    // ── Day votes subcollection — each voter writes only their own doc ─────
    match /games/{gameId}/votes/{voterUid} {
      // Anyone in the game may read (for vote count display)
      allow read: if isAuth();
      // Only the voter may create/update their own vote doc, and only during day phase
      allow create, update: if isAuth()
        && request.auth.uid == voterUid
        && get(/databases/$(database)/documents/games/$(gameId)).data.phase == 'day'
        && request.resource.data.keys().hasOnly(['target', 'round', 'submittedAt']);
      // Host may also write (for AI players)
      allow write: if isAuth() && isHost(gameId);
      allow delete: if false;
    }

    // ── Lobby / public chat ───────────────────────────────────────────────
    match /games/{gameId}/lobbyChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    match /games/{gameId}/publicChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    // ── Ghost chat ─────────────────────────────────────────────────────────
    match /games/{gameId}/ghostChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    // ── Wolf chat — only wolf-team members (wolfTeam map enforced) ────────
    match /games/{gameId}/wolfChat/{messageId} {
      allow read: if isAuth() && (
        isHost(gameId) ||
        get(/databases/$(database)/documents/games/$(gameId)).data.wolfTeam[request.auth.uid] == true
      );
      allow create: if isAuth() &&
        request.auth.uid == request.resource.data.senderId && (
          isHost(gameId) ||
          get(/databases/$(database)/documents/games/$(gameId)).data.wolfTeam[request.auth.uid] == true
        );
      allow update, delete: if false;
    }

    // ── Lovers chat — only the two lovers ────────────────────────────────
    match /games/{gameId}/loversChat/{messageId} {
      allow read: if isAuth() && (
        isHost(gameId) ||
        (
          get(/databases/$(database)/documents/games/$(gameId)).data.lovers != null &&
          (
            get(/databases/$(database)/documents/games/$(gameId)).data.lovers[0] == request.auth.uid ||
            get(/databases/$(database)/documents/games/$(gameId)).data.lovers[1] == request.auth.uid
          )
        )
      );
      allow create: if isAuth() &&
        request.auth.uid == request.resource.data.senderId && (
          get(/databases/$(database)/documents/games/$(gameId)).data.lovers != null &&
          (
            get(/databases/$(database)/documents/games/$(gameId)).data.lovers[0] == request.auth.uid ||
            get(/databases/$(database)/documents/games/$(gameId)).data.lovers[1] == request.auth.uid
          )
        );
      allow update, delete: if false;
    }

    match /games/{gameId}/twinChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    match /games/{gameId}/fairyChat/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if false;
    }

    match /games/{gameId}/nightActions/{actionId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    match /games/{gameId}/votes/{voteId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // ── Chat de voz WebRTC — señalización ─────────────────────────────
    match /games/{gameId}/voicePresence/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    match /games/{gameId}/voiceOffers/{offerId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
      allow update: if false;
    }

    match /games/{gameId}/voiceAnswers/{answerId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
      allow update: if false;
    }

    match /games/{gameId}/voiceIce/{pairId}/candidates/{candidateId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if false;
      allow update: if false;
    }
  }
}
